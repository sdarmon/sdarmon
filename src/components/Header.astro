---
import { ViewTransitions } from 'astro:transitions';
interface HeaderProps {
  title: string;
}
const { title } = Astro.props as HeaderProps;
// Import de la police (400 = texte normal, 700 = texte en gras)
// C'est mieux d'importer les deux si tu utilises du gras sur ton site !
import '@fontsource/exo-2/400.css';
import '@fontsource/exo-2/700.css';

import { ClientRouter } from 'astro:transitions';
---

<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
  <ViewTransitions />
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <meta name="color-scheme" content="dark">
  <link rel="icon" type="image/jpg+xml" href="/assets/profil%20(40%20x%2040%20px).svg" />
  <meta name="generator" content={Astro.generator} />
  <meta property="og:title" content="Sasha Darmon | Médiation & Recherche" />
  <meta property="og:description" content="Docteur en Bio-informatique et médiateur scientifique. Découvrez mes ateliers et conférences." />
  <meta property="og:image" content="https://sashadarmon.fr/assets/banner.jpg" />
  <meta property="og:url" content="https://sashadarmon.fr" />

  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content="https://sashadarmon.fr/" />
  <meta property="twitter:title" content="Sasha Darmon | Médiation & Recherche" />
  <meta property="twitter:description" content="Découvrez mes ateliers, mes publications et mon parcours." />
  <meta property="twitter:image" content="https://sashadarmon.fr/assets/banner.jpg" />

  <!-- 1. Le Titre SEO (environ 60 caractères) -->
  <title>{title} | Sasha Darmon - Médiation Scientifique & Bio-informatique</title>

  <!-- 2. La Description SEO (environ 155 caractères) -->
  <!-- C'est ce qui s'affiche en noir sous le lien bleu dans Google -->
  <meta name="description" content="Doctorant en bio-informatique (LBBE Lyon), je conçois et anime des ateliers de vulgarisation scientifique, des expositions et des conférences." />

  <!-- 3. Indiquer à Google que ton site est en français -->
  <ClientRouter />
  <meta content="width=device-width, initial-scale=1" name="viewport" />
  <link href="/assets/styles.css" rel="stylesheet" type="text/css" />
  <link href="https://fonts.googleapis.com/" rel="preconnect" />
  <link href="https://fonts.gstatic.com/" rel="preconnect" crossorigin="anonymous" />
  <!--[if lt IE 9]><script src="https://cdnjs.cloudflare.com/ajax/libs/html5shiv/3.7.3/html5shiv.min.js" type="text/javascript"></script><![endif]-->
  <script type="text/javascript">
    !(function (o, c) {
      var n = c.documentElement,
        t = " w-mod-";
      (n.className += t + "js"), ("ontouchstart" in o || (o.DocumentTouch && c instanceof DocumentTouch)) && (n.className += t + "touch");
    })(window, document);
  </script>
  <link href="/assets/profil%20(40%20x%2040%20px).svg" rel="shortcut icon" type="image/x-icon" />
  <link href="/assets/profil%20(40%20x%2040%20px).svg" rel="apple-touch-icon" />
</head>
