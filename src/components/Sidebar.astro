---
const { selectedItem } = Astro.props;
import { Image } from 'astro:assets';
import profilImg from '@/assets/profil.JPG';
import { ui } from '@/i18n/ui';

// 1. On récupère le chemin actuel (ex: /ateliers ou /en/ateliers)
const pathname = Astro.url.pathname;

// 2. On détecte la langue actuelle
const lang = pathname.startsWith('/en') ? 'en' : 'fr';
const t = ui[lang];

// 3. LOGIQUE DU SWITCHER : Calcul des URLs correspondantes
// Lien FR : on enlève le préfixe "/en" s'il existe
const frPath = lang === 'en'
    ? pathname.replace(/^\/en/, '') || '/'
    : pathname;

// Lien EN : on ajoute le préfixe "/en" s'il n'existe pas
const enPath = lang === 'fr'
    ? `/en${pathname === '/' ? '/' : pathname}`
    : pathname;

// Fonction utilitaire pour les liens du menu (inchangée)
const l = (path) => lang === 'fr' ? path : `/en${path === '/' ? '' : path}`;
---

<aside
    data-animation="default"
    data-collapse="medium"
    data-duration="400"
    data-easing="ease"
    data-easing2="ease"
    role="banner"
    class="sidebar w-nav"
>
  <div class="nav-content">
    <!-- Brand / Profil -->
    <a href={l('/')} class="w-nav-brand" aria-label="home">
      <div class="niv-data">
        <Image src={profilImg} alt="Sasha Darmon" class="niv-image" />
        <div>
          <div class="label-white"><b>Sasha Darmon</b></div>
          <!-- Traduction du titre sous le nom -->
          <div class="label-gray"><b>{lang === 'fr' ? 'Doctorant' : 'PhD Candidate'}</b></div>
        </div>
      </div>
    </a>

    <nav role="navigation" class="w-nav-menu">
      <!-- 1. Accueil -->
      <a
          href={l('/')}
          class={`nav-link-container w-inline-block ${selectedItem === 'home' ? 'w--current' : ''}`}
      >
        <img src="/assets/home.svg" loading="eager" alt="" class="nav-link-image" />
        <div>{t['nav.home']}</div>
      </a>

      <!-- 2. Ateliers Médiations -->
      <a
          href={l('/ateliers')}
          class={`nav-link-container w-inline-block ${selectedItem === 'ateliers' ? 'w--current' : ''}`}
      >
        <img src="/assets/puzzle.svg" loading="eager" alt="" class="nav-link-image" />
        <div>{t['nav.ateliers']}</div>
      </a>

      <!-- 3. Communication & Prix -->
      <a
          href={l('/communication-prix')}
          class={`nav-link-container w-inline-block ${selectedItem === 'communication' ? 'w--current' : ''}`}
      >
        <img src="/assets/trophy.svg" loading="eager" alt="" class="nav-link-image" />
        <div>{t['nav.com']}</div>
      </a>

      <!-- 4. Publications -->
      <a
          href={l('/publications')}
          class={`nav-link-container w-inline-block ${selectedItem === 'publications' ? 'w--current' : ''}`}
      >
        <img src="/assets/code.svg" loading="eager" alt="" class="nav-link-image" />
        <div>{t['nav.publi']}</div>
      </a>

      <!-- 5. CV -->
      <a
          href={l('/cv')}
          class={`nav-link-container w-inline-block ${selectedItem === 'cv' ? 'w--current' : ''}`}
      >
        <img src="/assets/cv.svg" loading="eager" alt="" class="nav-link-image" />
        <div>{t['nav.cv']}</div>
      </a>

      <!-- 6. Contact -->
      <a
          href={l('/contact')}
          class={`nav-link-container w-inline-block ${selectedItem === 'contact' ? 'w--current' : ''}`}
      >
        <img src="/assets/chat.svg" loading="eager" alt="" class="nav-link-image" />
        <div>{t['nav.contact']}</div>
      </a>
    </nav>

    <!-- Bouton Menu Mobile -->
    <div class="navbar-icon-button w-nav-button" role="button" tabindex="0">
      <img src="/assets/menu.svg" loading="eager" alt="" class="navbar-icon" />
    </div>

    <!-- SÉLECTEUR DE LANGUE -->
    <div class="lang-switcher">
      <!-- On utilise frPath au lieu de "/" -->
      <a href={frPath} class={lang === 'fr' ? 'active' : ''}>FR</a>

      <span class="separator">|</span>

      <!-- On utilise enPath au lieu de "/en/" -->
      <a href={enPath} class={lang === 'en' ? 'active' : ''}>EN</a>
    </div>
  </div>

  <script>
    import { setupNav } from '@/scripts/nav.js';
    let cleanup;
    document.addEventListener('astro:page-load', () => {
      if (cleanup) cleanup();
      cleanup = setupNav();
    });
    document.addEventListener('astro:before-swap', () => {
      if (cleanup) cleanup();
    });
  </script>
</aside>
