---
import Header from "@/components/Header.astro";
import Sidebar from "@/components/Sidebar.astro";
import Footer from "@/components/Footer.astro";
import "@/layouts/index.css";
---

<!DOCTYPE html>
<html lang="en">
<Header title="Outreach & Awards | Sasha Darmon" />
<body>
<div class="content">
    <Sidebar selectedItem="communication" />
    <nav class="main">
        <div class="container">
            <main class="fold-content-container">

                <a href="/en/" class="button w-button" style="margin-bottom: 32px; background-color: #353535; border-color: #353535;">← Back</a>

                <div class="fold-content">
                    <h1>Outreach & Awards</h1>
                    <p class="lead">
                        Sharing the passion for research through stage performance and writing. I explore various formats to tell the story of science differently.
                    </p>

                    <!-- THE CAROUSEL -->
                    <div class="carousel-container">

                        <!-- Left Arrow -->
                        <button class="carousel-arrow left-arrow" aria-label="Previous">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="24" height="24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
                        </button>

                        <div class="carousel-track">

                            <!-- SLIDE 1 : MISSION Z -->
                            <div class="carousel-slide" id="slide-bd">
                                <img src="/photo/A_illustration_sciencesenbulles_0.jpg" alt="Mission Z Graphic Novel Cover" class="card-cover-image" />

                                <!-- 2. Gradient overlay -->
                                <div class="card-gradient"></div>

                                <!-- 3. Text container -->
                                <div class="card-content-wrapper">
                                    <div class="card-basic">
                                        <div class="photo-credit-vertical">© Ollivier Pourriol & Nathanaël Mikles</div>
                                        <div class="mini-label-white gray-color">Graphic Novel Project</div>
                                        <h3>Mission Z. In Pursuit of Intelligence</h3>
                                        <p>Embark on a mission to discover "Intelligence(s)", whether natural, artificial, or human.</p>
                                        <div class="expand-hint">Click to learn more <span>+</span></div>
                                    </div>

                                    <div class="expanded-content">
                                        <p style="margin-bottom: 16px; margin-top: 10px;">
                                            In this graphic novel, Ollivier Pourriol (script) and Nathanaël Mikles
                                            (illustration) set out to find Intelligence(s), exploring natural,
                                            artificial, and human forms. Their story is inspired by the theses of eight
                                            PhD candidates, and I was honored to be one of them.
                                        </p>
                                        <p style="margin-bottom: 16px;">
                                            Aimed at a broad audience, this book seeks to raise awareness of the scientific
                                            and social challenges posed by artificial intelligence and invites readers to
                                            join the debate.
                                        </p>
                                        <p style="margin-bottom: 16px;">
                                            In addition to the book, a twelve-page activity booklet inspired by the story
                                            and created by the illustrator is also available.
                                        </p>
                                        <a href="/dwnld/MissionZ_2025_HD.pdf" target="_blank" class="button w-button">Read the Graphic Novel (PDF)</a>
                                    </div>
                                </div>
                            </div>

                            <!-- SLIDE 2 : MT180 -->
                            <div class="carousel-slide" id="slide-mt180">

                                <img src="/photo/Bartok_Vincent_Noclin.jpg" alt="Photo from MT180 competition in Lyon"  class="card-cover-image"/>

                                <div class="card-gradient"></div>
                                <div class="card-content-wrapper">
                                    <div class="card-basic">
                                        <div class="photo-credit-vertical">© Vincent Noclin</div>
                                        <div class="mini-label-white gray-color">Jury's 1st Prize</div>
                                        <h3>My Thesis in <a href="/180s" style="color: inherit; text-decoration: none; cursor: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2232%22 height=%2232%22 style=%22font-size:24px%22><text y=%2224%22>⏱️</text></svg>'), auto;">180 Seconds</a></h3>
                                        <p>Local final in Lyon: 3 minutes to convince.</p>
                                        <div class="expand-hint">Click to learn more <span>+</span></div>
                                    </div>

                                    <div class="expanded-content">
                                        <p style="margin-bottom: 16px; margin-top: 10px;">
                                            The challenge: explain your PhD thesis in under 3 minutes flat.
                                        </p>
                                        <p style="margin-bottom: 16px;">
                                            Among 33 candidates from the University of Lyon-St. Étienne, I was selected
                                            as one of the 12 finalists for the local Lyon final of the MT180 competition.
                                        </p>
                                        <p style="margin-bottom: 16px;">
                                            I successfully convinced the jury with my presentation on "Development of
                                            models and algorithms for managing repetitions in de novo transcriptome
                                            assembly."
                                        </p>
                                        <p style="margin-bottom: 16px;">
                                            Winning the Jury's 1st Prize allowed me to represent the University of
                                            Lyon-St. Étienne at the regional final. You can watch my performance below
                                            (in French).
                                        </p>

                                        <div class="video-wrapper">
                                            <iframe width="1050" height="590" src="https://www.youtube.com/embed/HU55znbeZxM" title="Ma thèse en 180 secondes 2026 | Sasha Darmon - 1er prix du jury" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- SLIDE 3 : DÉCRYP'THÈSE -->
                            <div class="carousel-slide" id="slide-decrypthese">
                                <img src="/photo/mais.jpg" alt="Intro slide for Décryp'thèse competition" class="card-cover-image" />

                                <div class="card-gradient"></div>

                                <div class="card-content-wrapper">
                                    <div class="card-basic">
                                        <div class="mini-label-white gray-color">Audience Award</div>
                                        <h3>Décryp'thèse Competition</h3>
                                        <p>Local science communication contest.</p>
                                        <div class="expand-hint">Click to learn more <span>+</span></div>
                                    </div>

                                    <div class="expanded-content">
                                        <p style="margin-bottom: 16px; margin-top: 10px;">
                                            Organized by the DocE2M2 association for the E2M2 doctoral school,
                                            this competition evaluates oral or poster presentations of PhD research,
                                            with the goal of promoting science outreach and highlighting the work of
                                            young researchers.
                                        </p>
                                        <p style="margin-bottom: 16px;">
                                            I was honored to receive the Audience Award for my talk during the 2025 edition.
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <!-- SLIDE 4 : Annonay -->
                            <div class="carousel-slide" id="slide-annonay">
                                <img src="/photo/annonay.jpeg" alt="Mini-conference at the Annonay theater" class="card-cover-image" />

                                <div class="card-gradient"></div>

                                <div class="card-content-wrapper">
                                    <div class="card-basic">
                                        <div class="mini-label-white">Science Festival</div>
                                        <h3>PhD Students Meet High Schoolers</h3>
                                        <p>An exchange about doctoral life at the Annonay Theatre.</p>
                                        <div class="expand-hint">Click to learn more  <span>+</span></div>
                                    </div>

                                    <div class="expanded-content">
                                        <p style="margin-bottom: 16px; margin-top: 10px;">
                                            As part of the 2025 Science Festival, the University of Lyon organized a
                                            meeting between 800 high school students and seven PhD students so they
                                            could discuss their career paths, research, and life as doctoral students.
                                        </p>
                                        <p style="margin-bottom: 16px;">
                                            I had the chance to take part in this event at the Annonay theater, sharing
                                            my journey and my research with the students.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Right Arrow -->
                        <button class="carousel-arrow right-arrow" aria-label="Next">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="24" height="24"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
                        </button>

                        <!-- NAVIGATION DOTS -->
                        <div class="carousel-nav">
                            <button class="nav-dot active" data-slide="0"></button>
                            <button class="nav-dot" data-slide="1"></button>
                            <button class="nav-dot" data-slide="2"></button>
                            <button class="nav-dot" data-slide="3"></button>
                        </div>
                    </div>

                </div>
            </main>
            <Footer />
        </div>
    </nav>
</div>

<script>
    import { initCarousel } from '@/scripts/carousel.js';
    document.addEventListener('astro:page-load', () => {
        initCarousel();
    });
</script>
</body>
</html>