---
import Header from "@/components/Header.astro";
import Sidebar from "@/components/Sidebar.astro";
import Footer from "@/components/Footer.astro";
import "@/layouts/index.css";
---

<!DOCTYPE html>
<html lang="en">
<Header title="Legal Notice | Sasha Darmon" />
<body>
<div class="content">
    <Sidebar selectedItem="" />
    <nav class="main">
        <div class="container">
            <main class="fold-content-container">

                <a href="/en/" class="button w-button" style="margin-bottom: 32px; background-color: #353535; border-color: #353535;">← Back</a>

                <div class="fold-content legal-content">
                    <h1>Legal Notice</h1>

                    <section style="margin-top: 40px;">
                        <div class="mini-label-white gray-color" style="color: #95ec38;">Publishing Information</div>
                        <p>This website is published by: <strong>Sasha Darmon</strong><br />
                            Email: contact@sashadarmon.fr</p>
                    </section>

                    <section style="margin-top: 30px;">
                        <div class="mini-label-white gray-color" style="color: #95ec38;">Hosting</div>
                        <p>This website is hosted by:<br />
                            <strong>GitHub Inc.</strong><br />
                            88 Colin P Kelly Jr St<br />
                            San Francisco, CA 94107, USA<br />
                            Website: <a href="https://pages.github.com" target="_blank" style="color: #3898ec;">https://pages.github.com</a></p>
                    </section>

                    <section style="margin-top: 30px;">
                        <div class="mini-label-white gray-color" style="color: #95ec38;">Intellectual Property</div>
                        <p>
                            Unless otherwise stated, all content (text, images, graphics, logos, icons) is the
                            exclusive property of Sasha Darmon. Any reproduction, representation, modification,
                            or publication, even partial, is prohibited without prior written authorization.
                        </p>
                        <p>Photos credited to third parties remain the property of their respective authors.</p>
                    </section>

                    <section style="margin-top: 30px;">
                        <div class="mini-label-white" style="color: #95ec38;">Privacy & Cookies</div>
                        <p>
                            This website is for informational purposes only. It does not use any tracking or
                            advertising cookies and does not collect personal data, except for information
                            voluntarily submitted by the user via the contact form (handled via Formspree).
                        </p>
                    </section>
                </div>
            </main>
            <Footer />
        </div>
    </nav>
</div>

<style>
    .legal-content p {
        color: #a8a8a8;
        line-height: 1.6;
        font-size: 1rem;
        margin-bottom: 20px;
    }
    .legal-content strong {
        color: #fff;
    }
</style>
</body>
</html>